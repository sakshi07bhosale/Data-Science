    "#Basic Feature Creation\n",
    "#result column\n",
    "import pandas as pd \n",
    "df = pd.read_csv(\"Student_dataset.csv\")\n",
    "df[\"Result\"] = df[\"Marks\"].apply(lambda x: \"Pass\" if x >= 75 else \"Fail\")\n",
    "print(df)"
