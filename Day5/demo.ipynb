   "source": [
    "#Creating New Columns\n",
    "import pandas as pd\n",
    "\n",
    "data = {\n",
    "    \"Name\": [\"A\", \"B\", \"C\"],\n",
    "    \"Marks\": [80, 60, 90]\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "# Add new column\n",
    "df[\"Result\"] = df[\"Marks\"].apply(lambda x: \"Pass\" if x >= 70 else \"Fail\")\n",
    "\n",
    "print(df)"
   ]
  },
